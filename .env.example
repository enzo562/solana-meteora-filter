# Client (SPA, VITE_-prefixed = embarqué dans le bundle public au build)
VITE_BIRDEYE_API_KEY=
VITE_SOLANATRACKER_API_KEY=

# Service d'alerting (alerter/) — secrets serveur, jamais VITE_-préfixés
# Canaux actifs, séparés par des virgules : "discord", "telegram", ou "discord,telegram"
ALERT_CHANNELS=

# Requis si ALERT_CHANNELS contient "discord"
DISCORD_WEBHOOK_URL=

# Requis si ALERT_CHANNELS contient "telegram"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optionnels (valeurs par défaut documentées dans docs/specs/meteora-pool-alerts/)
SCAN_INTERVAL_MS=60000
MIN_TVL_ALERT=0
EXCLUDE_BLACKLISTED=true
SEEN_POOLS_MAX=5000
